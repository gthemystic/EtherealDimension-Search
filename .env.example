# === Feature Flags ===
# Set to 'true' for full demo mode with mock data (no API keys needed)
NEXT_PUBLIC_MOCK_MODE=true
# MOCK_MODE=true

# Per-service overrides (uncomment to force mock for specific services)
# MOCK_SEARCH=true
# MOCK_CHAT=true
# MOCK_GRAPH=true
# MOCK_GITHUB=true
# MOCK_CRAWL=true
# MOCK_PROCESS=true
# MOCK_OCR=true

# === Search & AI ===
PERPLEXITY_API_KEY=pplx-...
GROQ_API_KEY=gsk_...

# === Code Search ===
GITHUB_PAT_TOKEN=ghp_...

# === Web Scraping ===
FIRECRAWL_API_KEY=fc-...

# === Graph Database ===
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=etherealdimension

# === n8n Multi-Agent Orchestration ===
N8N_WEBHOOK_URL=http://localhost:5678
N8N_API_KEY=

# === OCR Pipeline (optional - add keys as available) ===
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=

# === OpenAI ===
OPENAI_API_KEY=sk-proj-...

# === Redis (for caching & queues) ===
